class Solution {
    public boolean isPerfectSquare(int num) {
        int left = 1;
        int right = num;
        if(num<0) return false;
        if(num==1|| num==0){
            return true;
        }
         
         while(left<=right){
            long mid = left +(right-left)/2;
            long sqr = mid*mid;
            if(sqr==num){
                return true;
            }
            else if (sqr<num){
                left= (int)mid+1;
            }
            else{
                right =(int) mid-1;
            }
         }
         return false;

    }
}
